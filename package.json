{
  "name": "prompt-alchemy-server",
  "version": "1.0.0",
  "description": "Prompt 鍊金坊 Prompt Alchemy — Prompt/Skill 收藏庫後端 API server",
  "main": "server.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "test": "vitest run",
    "swagger": "node src/config/swagger.js",
    "dev": "cross-env NODE_ENV=development node --watch server.js",
    "dev:init": "node src/database/migrate.js",
    "dev:seed": "node src/database/seed.js",
    "dev:setup": "npm run dev:init && npm run dev:seed",
    "dev:clear": "node -e \"require('fs').rmSync('.pglite-data', { recursive: true, force: true })\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@google-cloud/storage": "^7.21.0",
    "@scalar/express-api-reference": "^0.10.8",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "cross-env": "^10.1.0",
    "vitest": "^4.1.9"
  }
}
