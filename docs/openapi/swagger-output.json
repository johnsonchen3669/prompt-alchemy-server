                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "name",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "member@example.com"
                  },
                  "name": {
                    "type": "string",
                    "format": "text",
                    "example": "member"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "Member1234"
                  }
                }
              }
            }
          }
        }
      }
    },
