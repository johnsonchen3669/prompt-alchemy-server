  "paths": {
    "/health/": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "確認服務存活狀態",
        "description": "確認服務正常運作",
        "responses": {
          "200": {
            "description": "服務正常運作",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "timestamp": {
                      "type": "string",
                      "example": "2026-07-17T12:00:00.000Z"
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "timestamp": {
                      "type": "string",
                      "example": "2026-07-17T12:00:00.000Z"
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/utility/upload": {
      "post": {
        "tags": [
          "Utility"
        ],
        "summary": "上傳檔案至 GCP Bucket",
        "description": "提供檔案上傳功能，並回傳公開可存取的 URL。",
        "responses": {
          "200": {
            "description": "檔案上傳成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "檔案上傳成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string",
                          "example": "https://storage.googleapis.com/my-bucket/123456789-1234.png"
                        }
                      }
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "檔案上傳成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string",
                          "example": "https://storage.googleapis.com/my-bucket/123456789-1234.png"
                        }
                      }
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              }
            }
          },
          "400": {
            "description": "上傳失敗 (例如未帶入檔案)"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "要上傳的檔案"
                  }
                }
              }
            }
          }
        }
      }
    },
