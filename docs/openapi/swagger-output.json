                    "example": "member@example.com"
                  },
                  "name": {
                    "type": "string",
                    "format": "text",
                    "example": "member"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "Member1234"
                  }
                }
              }
            }
          }
        }
      }
    },
