          "400": {
            "description": "欄位缺漏或 email 已被使用",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "false"
                    },
                    "message": {
                      "type": "string",
                      "example": "請填寫 email、name 與 password"
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "false"
                    },
                    "message": {
                      "type": "string",
                      "example": "請填寫 email、name 與 password"
                    }
