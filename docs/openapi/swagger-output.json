                    "message": {
                      "type": "string",
                      "example": "修改參數成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "format": "uuid",
                          "example": "755f3568-2333-4709-b916-582eae69e195"
                        },
                        "type": {
                          "type": "string",
                          "example": "category"
                        },
                        "name": {
                          "type": "string",
                          "example": "修改後的名稱"
                        },
                        "description": {
                          "type": "string",
                          "example": "修改後的說明"
                        },
                        "isActive": {
                          "type": "boolean",
                          "example": false
